# ─────────────────────────────────────────────────────────────
#  CLS Corp — AI Lead Qualification Agent  |  .env.example
#  Copy this file to .env and fill in your keys.
# ─────────────────────────────────────────────────────────────

# REQUIRED ─────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL — AI Model selection ────────────────────────────────
# Default: deepseek/deepseek-chat  (fast & affordable)
# Alternatives:
#   anthropic/claude-3-5-sonnet      (highest quality)
#   openai/gpt-4o-mini               (OpenAI fallback)
#   mistralai/mixtral-8x7b-instruct  (open-weight)
QUALIFIER_MODEL=deepseek/deepseek-chat
OUTREACH_MODEL=deepseek/deepseek-chat

# OPTIONAL — Sender identity for outreach emails ───────────────
SENDER_NAME=Alex Rivera
SENDER_TITLE=Head of AI Partnerships
SENDER_COMPANY=CLS Corp
SENDER_EMAIL=alex@clscorp.ai
SITE_URL=https://clscorp.ai
SITE_NAME=CLS Corp Lead Qualifier

# OPTIONAL — LinkedIn enrichment (real data) ───────────────────
# Register at https://nubela.co/proxycurl to get an API key
# Without this, LinkedIn enrichment returns a clearly-labelled stub.
# PROXYCURL_API_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
